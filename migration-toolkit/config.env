#!/bin/bash
# ═══════════════════════════════════════════════════════════
#  config.env — Storage 跨区域迁移配置文件
#  客户按实际情况填写，所有脚本从此文件读取参数
# ═══════════════════════════════════════════════════════════

# ─── 源端和目标端 Storage Account ───
SRC_ACCOUNT=""                   # 源端 SA 名称（例如 srcblob2026test）
DST_ACCOUNT=""                   # 目标端 SA 名称（例如 destblob2026test）
SRC_REGION="chinaeast"           # 源端区域（chinaeast / chinanorth）
DST_REGION="chinanorth3"         # 目标端区域

# ─── 存储类型 ───
STORAGE_TYPE="blob"              # blob 或 files

# ─── 容器/文件共享 ───
CONTAINER_NAME=""                # 留空 = 迁移整个 SA 下所有容器/共享
                                 # 填写 = 只迁移指定容器/共享（例如 mydata）

# ─── SAS Token ───
# 从 Azure Portal → SA → Security + networking → Shared access signature 生成
# 源端权限: rl (read + list)
# 目标端权限: rwdlac (read + write + delete + list + add + create)
# Resource types: sco (service + container + object)
# 有效期建议覆盖整个迁移周期
SRC_SAS=""                       # 源端 SAS（不含前导 ?）
DST_SAS=""                       # 目标端 SAS

# ─── 性能调优 ───
MAX_PARALLEL_JOBS=3              # 允许同时运行的 azcopy 作业数
                                 # 建议值: 1-5
                                 # Standard SA: 建议 3
                                 # Premium SA: 可调高到 5
AZCOPY_CONCURRENCY=128           # 单个 azcopy job 内部并发数
                                 # 建议值: 64-256
                                 # 跨区域场景不建议超过 256（过高会导致连接堆积/崩溃）
                                 # azcopy 默认值: 300（同区域），跨区域建议调低

# ─── 分批策略 ───
MAX_FILES_PER_BATCH=8000000      # 单个 batch 最大文件数（默认 800 万）
                                 # AzCopy 建议单 Job < 1000 万文件
MAX_GB_PER_BATCH=10000           # 单个 batch 最大数据量（GB，默认 10 TB）
                                 # 文件数 OR 数据量任一超限即按顶层目录拆分
                                 # 大数据量场景建议调低（如 5000 = 5TB）以并行加速

# ─── 费用估算 ───
DELTA_SYNC_RATIO=0.01            # 每次增量同步预估涉及的数据比例（默认 1%）
                                 # 表示每次 delta 同步约传输总数据量的 1%
                                 # 费用估算 = 3次 × 此比例 × 总数据量
                                 # 源端写入频繁可调高（如 0.03 = 3%）

# ─── 目录配置 ───
LOG_DIR="/data/azcopy-logs"      # 日志目录
PLAN_DIR="/data/azcopy-plans"    # azcopy job plan 目录
